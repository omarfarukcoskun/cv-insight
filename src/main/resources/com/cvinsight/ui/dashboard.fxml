<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cvinsight.ui.controllers.DashboardController"
            stylesheets="@styles.css"
            style="-fx-background-color: #f8fafc;">

    <!-- ── Sticky Nav Bar ─────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="dash-nav" alignment="CENTER_LEFT" spacing="12">

            <!-- Logo + tagline -->
            <VBox spacing="1">
                <Label text="CV Insight" styleClass="dash-logo"/>
                <Label text="Build stronger resumes" styleClass="dash-tagline"/>
            </VBox>

            <HBox HBox.hgrow="ALWAYS"/>

            <!-- User avatar circle -->
            <Label fx:id="userAvatarLabel" styleClass="user-avatar" minWidth="38" minHeight="38"/>

            <!-- Name + role -->
            <VBox spacing="1" alignment="CENTER_LEFT">
                <Label fx:id="userNameLabel" styleClass="dash-user-name"/>
                <Label text="My Account" styleClass="dash-user-role"/>
            </VBox>

            <Button text="Log out" onAction="#handleLogout" styleClass="nav-button"/>
        </HBox>
    </top>

    <!-- ── Scrollable Body ────────────────────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="dash-scroll">
            <VBox spacing="32" maxWidth="Infinity"
                  style="-fx-padding: 36 48 48 48;">

                <!-- 1. Hero welcome -->
                <VBox spacing="6">
                    <Label fx:id="welcomeLabel" styleClass="dash-welcome"/>
                    <Label text="Manage your resumes, track improvements, and optimize your chances of getting interviews."
                           styleClass="dash-hero-sub" maxWidth="600"/>
                </VBox>

                <!-- 2. Stats row — filled programmatically -->
                <HBox fx:id="statsRow" spacing="16"/>

                <!-- 3. Quick Actions — filled programmatically -->
                <VBox spacing="14">
                    <Label text="Quick Actions" styleClass="dash-section-title"/>
                    <HBox fx:id="actionsRow" spacing="16"/>
                </VBox>

                <!-- 4. Recent Resumes — filled programmatically -->
                <VBox spacing="14">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Recent Resumes" styleClass="dash-section-title"/>
                    </HBox>
                    <VBox fx:id="historyContainer" spacing="8">
                        <!-- rows injected by controller; empty-state also injected -->
                    </VBox>
                </VBox>

                <!-- 5. AI Tips — filled programmatically -->
                <VBox fx:id="tipsSection" spacing="14" managed="false" visible="false">
                    <Label text="AI Recommendations" styleClass="dash-section-title"/>
                    <VBox fx:id="tipsContainer" spacing="8"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
