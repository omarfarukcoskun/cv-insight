<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cvinsight.ui.controllers.LoginController"
      alignment="CENTER" spacing="0"
      stylesheets="@styles.css">

    <!-- Full-height centering wrapper -->
    <VBox alignment="CENTER" spacing="24" maxWidth="380"
          VBox.vgrow="ALWAYS" style="-fx-padding: 48 0 48 0;">

        <!-- Logo / Title -->
        <VBox alignment="CENTER" spacing="6">
            <Label text="CV Insight" styleClass="title-label"/>
            <Label text="Sign in to your account" styleClass="subtitle-label"/>
        </VBox>

        <!-- Card -->
        <VBox styleClass="card" spacing="14" maxWidth="360">

            <Label text="Email"/>
            <TextField fx:id="emailField" promptText="you@example.com"/>

            <Label text="Password"/>
            <PasswordField fx:id="passwordField" promptText="Password"/>

            <Label fx:id="errorLabel" styleClass="error-label"
                   visible="false" managed="false" wrapText="true"/>

            <Button fx:id="loginButton" text="Login"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    styleClass="primary-button"/>

            <Button text="Don't have an account? Register"
                    onAction="#handleGoToRegister"
                    maxWidth="Infinity"
                    styleClass="link-button"/>
        </VBox>
    </VBox>
</VBox>
