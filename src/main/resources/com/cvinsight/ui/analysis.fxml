<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cvinsight.ui.controllers.AnalysisController"
            stylesheets="@styles.css"
            style="-fx-background-color: #f5f5f5;">

    <!-- ── Nav bar — white surface, matches dashboard ────────────────────── -->
    <top>
        <HBox styleClass="dash-nav" alignment="CENTER_LEFT" spacing="16">
            <Button text="← Dashboard" onAction="#handleBack" styleClass="nav-button"/>
            <Label text="CV Analysis" styleClass="dash-logo"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button fx:id="reRunButton" text="Re-analyze"
                    onAction="#handleReRun" styleClass="secondary-button"
                    visible="false" managed="false"/>
        </HBox>
    </top>

    <!-- ── Main content ──────────────────────────────────────────────────── -->
    <center>
        <StackPane>

            <!-- Loading state -->
            <VBox fx:id="loadingPane" alignment="CENTER" spacing="16"
                  style="-fx-padding: 64;">
                <Label text="Analyzing your CV…"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <ProgressBar fx:id="progressBar" prefWidth="360" progress="0"
                             style="-fx-accent: #4f46e5;"/>
                <Label fx:id="statusLabel" text="Preparing…" styleClass="subtitle-label"/>
            </VBox>

            <!-- Results — visible after analysis completes -->
            <ScrollPane fx:id="resultsPane" fitToWidth="true"
                        visible="false" managed="false"
                        styleClass="dash-scroll">
                <HBox spacing="20" style="-fx-padding: 28 32 32 32;" alignment="TOP_LEFT">

                    <!-- Left column: score card + compare button -->
                    <VBox spacing="12" prefWidth="210" minWidth="190">

                        <!-- Score card -->
                        <VBox styleClass="analysis-score-card" spacing="14" alignment="CENTER">
                            <Label text="OVERALL SCORE" styleClass="analysis-score-title"/>
                            <VBox fx:id="scoreCardContainer" alignment="CENTER"/>
                            <Label fx:id="cvNameLabel" styleClass="subtitle-label"
                                   wrapText="true" maxWidth="180"
                                   style="-fx-font-size: 12px; -fx-alignment: center; -fx-text-alignment: center;"/>
                            <Label fx:id="analyzedAtLabel" styleClass="subtitle-label"
                                   style="-fx-font-size: 11px;"/>
                        </VBox>

                        <!-- Compare action -->
                        <Button text="Compare with Examples"
                                onAction="#handleCompare"
                                styleClass="secondary-button"
                                maxWidth="Infinity"/>
                    </VBox>

                    <!-- Right column: feedback sections -->
                    <VBox fx:id="feedbackContainer" HBox.hgrow="ALWAYS"
                          styleClass="analysis-feedback-card" spacing="0"/>

                </HBox>
            </ScrollPane>

            <!-- Error state -->
            <VBox fx:id="errorPane" alignment="CENTER" spacing="16"
                  visible="false" managed="false"
                  style="-fx-padding: 64;">
                <Label text="Analysis Failed"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #dc2626;"/>
                <Label fx:id="errorMessageLabel" wrapText="true"
                       maxWidth="460" textAlignment="CENTER"
                       styleClass="subtitle-label"/>
                <HBox spacing="12" alignment="CENTER">
                    <Button text="Try Again"    onAction="#handleReRun" styleClass="primary-button"/>
                    <Button text="← Dashboard" onAction="#handleBack"  styleClass="secondary-button"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
