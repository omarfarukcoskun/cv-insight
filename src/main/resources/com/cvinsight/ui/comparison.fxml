<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cvinsight.ui.controllers.ComparisonController"
            stylesheets="@styles.css">

    <top>
        <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="16">
            <Button text="← Back" onAction="#handleBack" styleClass="nav-button"/>
            <Label text="Successful CV Examples" styleClass="nav-title"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="14" style="-fx-padding: 20; -fx-min-width: 200; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 1 0 0;">
            <Label text="Filter By" styleClass="section-heading"/>

            <Label text="Category"/>
            <ComboBox fx:id="categoryFilter" maxWidth="Infinity" promptText="All"/>

            <Label text="Company"/>
            <ComboBox fx:id="companyFilter" maxWidth="Infinity" promptText="All"/>

            <Button text="Apply Filter" onAction="#handleFilter"
                    styleClass="primary-button" maxWidth="Infinity"/>
            <Button text="Clear" onAction="#handleClear"
                    styleClass="link-button" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="12" style="-fx-padding: 24;">
            <Label text="Examples" styleClass="section-heading"/>
            <ScrollPane fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox fx:id="examplesContainer" spacing="12">
                    <Label fx:id="emptyLabel" text="No examples found."
                           styleClass="subtitle-label" visible="false" managed="false"/>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
